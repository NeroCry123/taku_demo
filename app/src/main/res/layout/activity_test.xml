<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <Button
                android:layout_marginTop="20dp"
                android:id="@+id/btn_init"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="初始化"/>

            <Button
                android:layout_marginTop="20dp"
                android:id="@+id/btn_splash"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="加载和显示开屏"/>

            <Button
                android:id="@+id/btn_reward"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="加载和显示激励视频"/>

            <Button
                android:id="@+id/btn_interstitial"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="加载和显示插屏"/>

            <Button
                android:id="@+id/btn_native"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="加载和显示信息流"/>

            <Button
                android:id="@+id/btn_banner"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="加载和显示横幅"/>

            <LinearLayout
                android:id="@+id/layout_ad_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"/>
        </LinearLayout>
    </ScrollView>


</LinearLayout>